generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  passwordHash        String
  startingBalanceCents Int           @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  categories          Category[]
  expenses            Expense[]
  incomes             Income[]
  budgets             MonthlyBudget[]
  goals               Goal[]
  mileageTrips        MileageTrip[]
}

model Category {
  id        String          @id @default(cuid())
  userId    String
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  budgets   MonthlyBudget[]

  @@unique([userId, name])
  @@index([userId, isActive])
}

model Expense {
  id              String   @id @default(cuid())
  userId          String
  categoryId      String
  amountCents     Int
  spentOn         DateTime
  note            String?
  isTaxDeductible Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId, spentOn])
  @@index([userId, categoryId, spentOn])
  @@index([userId, isTaxDeductible, spentOn])
}

model MonthlyBudget {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  monthKey    String
  budgetCents Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([userId, categoryId, monthKey])
  @@index([userId, monthKey])
}

model Income {
  id          String   @id @default(cuid())
  userId      String
  amountCents Int
  receivedOn  DateTime
  source      String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, receivedOn])
}

enum GoalType {
  house
  student_debt
  emergency
  car
  vacation
  other
}

model Goal {
  id               String    @id @default(cuid())
  userId           String
  name             String
  type             GoalType  @default(other)
  targetAmountCents Int
  savedAmountCents Int       @default(0)
  targetDate       DateTime?
  note             String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, type])
}

model MileageTrip {
  id            String   @id @default(cuid())
  userId        String
  milesTimes100 Int
  tripDate      DateTime
  purpose       String?
  note          String?
  isReimbursed  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tripDate])
}
